<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_steadfast_form" model="ir.ui.view">
        <field name="name">betopia.steadfast.form</field>
        <field name="model">betopia.steadfast</field>
        <field name="arch" type="xml">
            <form string="Steadfast Order">
                <header>
                    <button class="btn-primary" type="object" name="action_send_to_steadfast" string="Create Shipment"/>
                    <button class="btn-primary" type="object" name="action_fetch_and_show_tracking" string="Check Tracking Updates"/>
                </header>
                
             <sheet>
                    <group>
                    
                        <field name="name"/>
                        <field name="steadfast_account_id"/>
                        <field name="status"/>
                        <field name = "date_ordered"/>
                        <field name = "date_shipped"/>
                        <field name="tracking" string="Tracking Code"/>
                        <field name="sale_order_id" string="Sale Order" />

                    </group>

             <notebook>
                <page string="Order History">
                    <field name="history_line_ids">
                        <list>
                            <field name="consignment_id"/>
                            <field name="invoice"/>
                            <field name="tracking_code"/>
                            <field name="status"/>
                            <field name="created_at"/>
                            <field name="updated_at"/>
                        </list>
                    </field>
                </page>
            </notebook>
            
        </sheet>
            </form>
        </field>
    </record>
    <record id="view_steadfast_form_account" model="ir.ui.view">
        <field name="name">betopia.steadfast.form.account</field>
        <field name="model">betopia.steadfast.account</field>
        <field name="arch" type="xml">
            <form string="Steadfast Account">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="api_key"/>
                        <field name="secret_key"/>
                        <field name="base_url"/>
                    </group>

                <notebook>
                    <page string="Bangladesh Pricing Rules">
                        <field name="pricing_ids"> <!-- one2many relation -->
                                <list string="Steadfast Pricing" create="true" delete="true" edit="true">
                                    <field name="weight_min"/>
                                    <field name="weight_max"/>
                                    <field name="base_cost"/>
                                    <field name="zone_extra"/>
                                    <field name="speed_extra"/>
                                    <field name="cod_percent"/>
                                </list>
                            </field>
                        </page>
                </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="view_steadfast_list" model="ir.ui.view">
        <field name="name">betopia.steadfast.list</field>
        <field name="model">betopia.steadfast</field>
        <field name="arch" type="xml">
            <list string="Steadfast Orders">
                <field name="name"/>
                <field name="invoice"/>
                <field name="tracking"/>
                <field name="status"/>
            </list>
        </field>
    </record>


    <!--inherited views with sales order and steadfast -->

    <data>
        <record id="inherit_sale_order_form_steadfast" model="ir.ui.view">
            <field name="name">inherit.sale.order.form.steadfast</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_term_id']" position="after">
                    <field name="steadfast_id"/>
                    <field name="steadfast_status" readonly="1"/>
                    <field name="steadfast_tracking_code" readonly="1"/>
                    <field name="steadfast_consignment_id" readonly="1"/>
                    <field name="steadfast_sent" readonly="1"/>

                     <button name="action_check_delivery_status"
                    type="object"
                    string="View Steadfast Order"
                    class="oe_highlight"
                    invisible="not steadfast_id"/>

                </xpath>

                <xpath expr="//header" position="inside">
                    <button name="action_confirm_stead_fast"
                            string="Send to Steadfast"
                            type="object"
                            class="btn-primary"/>

            
                </xpath>


            </field>
        </record>

    </data>


    <record id="action_steadfast" model="ir.actions.act_window">
        <field name="name">Steadfast Orders</field>
        <field name="res_model">betopia.steadfast</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Steadfast Order!
            </p>
        </field>
    </record>


    <!--inherited with account views-->
    
    <record id="action_steadfast_account" model="ir.actions.act_window">
        <field name="name">Steadfast Accounts</field>
        <field name="res_model">betopia.steadfast.account</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Steadfast Account!
            </p>
        </field>
    </record>


    <!--Traking History view .-->

      <record id="view_steadfast_tracking_form" model="ir.ui.view">
        <field name="name">steadfast.tracking.form</field>
        <field name="model">betopia.steadfast.tracking</field>
        <field name="arch" type="xml">
            <form string="Steadfast Tracking">
                <sheet>
                    <group>
                        <field name="consignment_id" string="Consignment ID"/>
                        <field name="customer_name" string="Customer Name"/>
                        <field name="customer_address" string="Address"/>
                        <field name="customer_phone" string="Phone"/>
                        <field name="current_hub" string="Current Hub"/>
                        <field name="rider_name" string="Rider Name"/>
                        <field name="rider_phone" string="Rider Phone"/>
                        <field name="cod_amount" string="COD Amount"/>
                        <field name="status" string="Status"/>
                    </group>

                    <!-- One2many Tracking Lines -->
                    <notebook>
                        <page string="Tracking History">
                            <field name="tracking_lines">
                                <list string="Tracking History" editable="bottom">
                                    <field name="message" string="Message"/>
                                    <field name="created_at" string="Date"/>
                                    <field name="deliveryman" string="Deliveryman"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree/List View -->
    <record id="view_steadfast_tracking_tree" model="ir.ui.view">
        <field name="name">steadfast.tracking.tree</field>
        <field name="model">betopia.steadfast.tracking</field>
        <field name="arch" type="xml">
            <list string="Steadfast Tracking List">
                <field name="consignment_id" string="Consignment ID"/>
                <field name="customer_name" string="Customer Name"/>
                <field name="current_hub" string="Current Hub"/>
                <field name="status" string="Status"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_steadfast_tracking" model="ir.actions.act_window">
        <field name="name">Steadfast Tracking</field>
        <field name="res_model">betopia.steadfast.tracking</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="menu_steadfast_root" name="Steadfast" sequence="10"/>
    <menuitem id="menu_steadfast_orders" name="Orders" parent="menu_steadfast_root" action="action_steadfast" sequence="10"/>
    <menuitem id="menu_steadfast_account" name="Stead Account" parent="menu_steadfast_root" action="action_steadfast_account" sequence="20"/>

</odoo>
