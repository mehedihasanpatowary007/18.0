<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_user_otp" model="mail.template">
            <field name="name">Mail Template for OTP</field>
            <field name="model_id" ref="meta_otp_auth.model_meta_otp_auth" />
            <field name="subject">{{ object.company_id.name}} Verification OTP.</field>
            <field name="email_from">{{ object.company_id.email_formatted }}</field>
            <field name="partner_to">{{ object.partner_id.id if object.partner_id.email else False
                }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;"> প্রিয় <t
                            t-if="object.partner_id">
                            <t t-out="object.partner_id.name"></t>
                        </t> <t
                            t-else="">গ্রাহক</t>
                        <br />
                        <br />
                        <t>
                            <br></br> আপনার ওটিপি হল <strong>
                                <t t-out="object.otp">123456</t>
                            </strong>.
                        মেয়াদ কাল <t
                                t-out="object.expire_time">120</t> সেকেন্ডস. <br></br>
                        </t>
                        <br></br>
                         <br></br>


                    </p>
                </div>
            </field>
            <field name="lang">{{object.partner_id.lang}}</field>
            <field name="auto_delete" eval="True" />
        </record>
    </data>
</odoo>