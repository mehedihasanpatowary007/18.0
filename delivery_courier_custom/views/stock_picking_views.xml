<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Stock Picking Form View -->
    <record id="view_picking_form_courier" model="ir.ui.view">
        <field name="name">stock.picking.form.courier</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="priority">999</field>
        <field name="arch" type="xml">

            <!-- Replace state field for incoming pickings -->
            <xpath expr="//field[@name='state'][@invisible=&quot;picking_type_code != 'incoming'&quot;]" position="replace">
                <field name="state" widget="statusbar" invisible="picking_type_code != 'incoming'" statusbar_visible="draft,assigned,courier_assigned,done"/>
            </xpath>

            <!-- Replace state field for outgoing/internal pickings -->
            <xpath expr="//field[@name='state'][@invisible=&quot;picking_type_code == 'incoming'&quot;]" position="replace">
                <field name="state" widget="statusbar" invisible="picking_type_code == 'incoming'" statusbar_visible="draft,confirmed,assigned,courier_assigned,done"/>
            </xpath>

            <!-- Hide the second duplicate Validate button -->
            <xpath expr="//button[@name='button_validate'][hasclass('o_btn_validate')]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Update first Validate button to show for assigned and courier_assigned states -->
            <xpath expr="//button[@name='button_validate'][hasclass('oe_highlight')]" position="attributes">
                <attribute name="invisible">state not in ('assigned', 'courier_assigned', 'waiting')</attribute>
            </xpath>

            <!-- Add courier buttons in the header -->
            <xpath expr="//header" position="inside">
                <button name="action_send_courier"
                        string="Send Courier"
                        type="object"
                        class="btn-primary"
                        invisible="not show_send_courier"
                        groups="stock.group_stock_user"/>
            </xpath>

            <!-- Add invisible fields for button visibility computation -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="show_send_courier" invisible="1"/>
            </xpath>

        </field>
    </record>

    <!-- Inherit Stock Picking Tree View -->
    <record id="view_picking_tree_courier" model="ir.ui.view">
        <field name="name">stock.picking.tree.courier</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="courier_name" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Add courier filter in search view -->
    <record id="view_picking_internal_search_courier" model="ir.ui.view">
        <field name="name">stock.picking.search.courier</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='late']" position="after">
                <separator/>
                <filter string="Ready for Courier" name="ready_courier"
                        domain="[('state', '=', 'assigned')]"/>
                <filter string="With Courier" name="with_courier"
                        domain="[('state', '=', 'courier_assigned')]"/>
                <filter string="Delivered" name="delivered"
                        domain="[('state', '=', 'done')]"/>
            </xpath>
        </field>
    </record>

</odoo>
