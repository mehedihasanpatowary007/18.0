                </div>
            </div>
        </xpath>
    </template>

    <template id="template_preheader_style_4" inherit_id="website.layout" name="Preheader Style - 4" active="False">
         <xpath expr="//header/*" position="before">
            <div class="tp-preheader o_colored_level o_cc" data-name="Preheader">
                <style type="text/css">
                    
                    .tp-preheader {
                        font-size: 14px;
                        padding: 5px 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        border-bottom: 1px solid rgba(var(--o-cc-text-rgb), 0.1);
                    }
    
                    .tp-preheader .container {
                        max-width: 1140px;
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        gap: 2rem;
                    }
    
                    .tp-warning-wrapper {
                        flex: 1;
                        overflow: hidden;
                        position: relative;
                        max-width: 60%;
                        white-space: nowrap;
                    }
    
                    .tp-warning-track {
                        display: inline-block;
                        white-space: nowrap;
                        animation: tp-scroll 25s linear infinite;
                        padding-left: 100%;
                    }
    
                    .tp-warning-track::after {
                        content: attr(data-text);
                        padding-left: 4rem;
                    }
    
                    .tp-warning-text {
                        display: inline-block;
                        color: var(--o-cc-text);
                        font-weight: 500;
                        letter-spacing: 0.4px;
                        padding-right: 4rem;
                    }
    
                    @keyframes tp-scroll {
                        0% { transform: translateX(0); }
                        100% { transform: translateX(-100%); }
                    }
    
                    .tp-warning-wrapper:hover .tp-warning-track {
                        animation-play-state: paused;
                    }
    
                    .tp-links ul {
                        list-style: none;
                        display: flex;
                        gap: 1.2rem;
                        margin: 0;
                        padding: 0;
                    }
    
                    .tp-links a {
                        color: var(--o-cc-text);
                        opacity: 0.8;
                        text-decoration: none;
                        transition: all 0.3s ease;
                        font-weight: 500;
                    }
    
                    .tp-links a:hover {
                        opacity: 1;
                        color: var(--o-cc-text);
                    }
    
                    @media (max-width: 991px) {
                        .tp-warning-wrapper {
                            max-width: 100%;
                        }
                        .tp-links {
                            display: none;
                        }
                        .tp-warning-text {
                            font-size: 13px;
                        }
                        .tp-warning-track {
                            animation-duration: 20s;
                        }
                    }
                </style>
    
                <div class="container">
                    <!-- Scrolling Warning -->
                    <div class="tp-warning-wrapper">
                        <div class="tp-warning-track"
                            data-text=" WARNING: This product contains nicotine. Nicotine is an addictive chemical. ">
                            <span class="tp-warning-text">
                                WARNING: This product contains nicotine. Nicotine is an addictive chemical.
                            </span>
                        </div>
                    </div>
    
                    <!-- Links -->
                    <div class="tp-links d-none d-lg-block">
                        <ul>
                            <li><a href="#">Contact&#160;Us</a></li>
                            <li><a href="#">About&#160;Us</a></li>
                            <li><a href="#">Terms</a></li>
                            <li><a href="#">FAQ</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </xpath>
    </template>


