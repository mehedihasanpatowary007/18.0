<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Access Rights for POS Dashboard -->
        <record id="access_pos_dashboard_user" model="ir.model.access">
            <field name="name">pos.dashboard.user</field>
            <field name="model_id" ref="model_pos_dashboard"/>
            <field name="group_id" ref="point_of_sale.group_pos_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_pos_dashboard_manager" model="ir.model.access">
            <field name="name">pos.dashboard.manager</field>
            <field name="model_id" ref="model_pos_dashboard"/>
            <field name="group_id" ref="point_of_sale.group_pos_manager"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>
</odoo>
