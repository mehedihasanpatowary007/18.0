<odoo>
    <!-- Inherit POS Order Form View -->
    <record id="view_pos_order_form_inherit_report_filter" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.report.filter</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <!-- Add new fields after partner_id -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="report_category"/>
                <field name="priority_level"/>
                <field name="sales_region"/>
                <field name="customer_segment"/>
                <field name="payment_status"/>
                <field name="order_age"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit POS Order Tree/List View -->
    <record id="view_pos_order_tree_inherit_report_filter" model="ir.ui.view">
        <field name="name">pos.order.tree.inherit.report.filter</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <!-- Add new columns -->
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="report_category" optional="hide"/>
                <field name="priority_level" optional="show"/>
                <field name="sales_region" optional="hide"/>
                <field name="customer_segment" optional="show"/>
                <field name="payment_status" optional="show"/>
                <field name="session_state" optional="hide"/>
                <field name="order_age" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit POS Order Search View -->
    <record id="view_pos_order_search_inherit_report" model="ir.ui.view">
        <field name="name">pos.order.search.inherit.report.filter</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_filter"/>
        <field name="arch" type="xml">
            <!-- Add new search filters -->
            <xpath expr="//filter[@name='order_date']" position="after">
                <separator/>
                <filter string="High Priority" name="high_priority"
                        domain="[('priority_level', '=', 'high')]"/>
                <filter string="Urgent Priority" name="urgent_priority"
                        domain="[('priority_level', '=', 'urgent')]"/>
                <separator/>
                <filter string="Payment Pending" name="payment_pending"
                        domain="[('payment_status', '=', 'pending')]"/>
                <filter string="Fully Paid" name="fully_paid"
                        domain="[('payment_status', '=', 'paid')]"/>
                <separator/>
                <filter string="VIP Customers" name="vip_customers"
                        domain="[('customer_segment', '=', 'vip')]"/>
                <filter string="Regular Customers" name="regular_customers"
                        domain="[('customer_segment', '=', 'regular')]"/>
            </xpath>

            <!-- Add search fields -->
            <xpath expr="//field[@name='config_id']" position="after">
                <field name="report_category"/>
                <field name="sales_region"/>
                <field name="customer_segment"/>
            </xpath>

            <!-- Add group by options at the end -->
            <xpath expr="//search" position="inside">
                <group expand="0" string="Group By">
                    <filter string="Point of Sale" name="group_pos_config"
                            context="{'group_by': 'config_id'}"/>
                    <filter string="Report Category" name="group_report_category"
                            context="{'group_by': 'report_category'}"/>
                    <filter string="Priority Level" name="group_priority"
                            context="{'group_by': 'priority_level'}"/>
                    <filter string="Sales Region" name="group_region"
                            context="{'group_by': 'sales_region'}"/>
                    <filter string="Customer Segment" name="group_customer_segment"
                            context="{'group_by': 'customer_segment'}"/>
                    <filter string="Payment Status" name="group_payment_status"
                            context="{'group_by': 'payment_status'}"/>
                    <filter string="Session State" name="group_session_state"
                            context="{'group_by': 'session_state'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
