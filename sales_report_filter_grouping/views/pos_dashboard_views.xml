<odoo>
    <!-- POS Dashboard Form View -->
    <record id="view_pos_dashboard_form" model="ir.ui.view">
        <field name="name">pos.dashboard.form</field>
        <field name="model">pos.dashboard</field>
        <field name="arch" type="xml">
            <form string="POS Dashboard" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_from" widget="date"/>
                        </group>
                        <group>
                            <field name="date_to" widget="date"/>
                        </group>
                    </group>

                    <!-- Summary Statistics -->
                    <group string="Summary Statistics">
                        <group>
                            <label for="total_orders" string="Total Orders"/>
                            <div class="o_row">
                                <button name="action_view_orders" type="object" class="oe_link">
                                    <field name="total_orders" readonly="1" class="oe_inline"/>
                                </button>
                            </div>
                            <field name="total_revenue" widget="monetary" readonly="1"/>
                            <field name="average_order_value" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_margin" widget="monetary" readonly="1"/>
                            <field name="profit_margin_percentage" widget="percentage" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- Payment Statistics -->
                    <group string="Payment Statistics">
                        <group>
                            <label for="paid_orders" string="Paid Orders"/>
                            <div class="o_row">
                                <button name="action_view_paid_orders" type="object" class="oe_link">
                                    <field name="paid_orders" readonly="1" class="oe_inline"/>
                                </button>
                            </div>
                        </group>
                        <group>
                            <label for="pending_orders" string="Pending Orders"/>
                            <div class="o_row">
                                <button name="action_view_pending_orders" type="object" class="oe_link">
                                    <field name="pending_orders" readonly="1" class="oe_inline"/>
                                </button>
                            </div>
                            <field name="partial_payment_orders" readonly="1"/>
                        </group>
                    </group>

                    <!-- Customer Statistics -->
                    <group string="Customer Statistics">
                        <group>
                            <field name="total_customers" readonly="1"/>
                            <field name="new_customers" readonly="1"/>
                        </group>
                        <group>
                            <field name="vip_customers" readonly="1"/>
                            <field name="regular_customers" readonly="1"/>
                        </group>
                    </group>

                    <!-- Category Statistics -->
                    <group string="Category Statistics">
                        <group>
                            <field name="retail_orders" readonly="1"/>
                            <field name="wholesale_orders" readonly="1"/>
                        </group>
                        <group>
                            <field name="online_orders" readonly="1"/>
                            <field name="direct_orders" readonly="1"/>
                        </group>
                    </group>

                    <!-- Session Statistics -->
                    <group string="Session Statistics">
                        <group>
                            <field name="active_sessions" readonly="1"/>
                        </group>
                        <group>
                            <field name="closed_sessions" readonly="1"/>
                        </group>
                    </group>

                    <!-- Regional Statistics -->
                    <group string="Regional Sales">
                        <group>
                            <field name="central_sales" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="international_sales" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- POS Dashboard Kanban View with KPI Tiles -->
    <record id="view_pos_dashboard_kanban" model="ir.ui.view">
        <field name="name">pos.dashboard.kanban</field>
        <field name="model">pos.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard o_pos_dashboard" create="false" edit="false">
                <field name="total_orders"/>
                <field name="total_revenue"/>
                <field name="average_order_value"/>
                <field name="total_margin"/>
                <field name="profit_margin_percentage"/>
                <field name="paid_orders"/>
                <field name="pending_orders"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card_header">
                            <div class="o_kanban_card_header_title">
                                <div class="o_primary">
                                    <field name="name"/>
                                </div>
                                <div class="o_secondary">
                                    <field name="date_from"/> - <field name="date_to"/>
                                </div>
                            </div>
                        </div>
                        <div class="container o_kanban_card_content">
                            <div class="row">
                                <!-- Revenue Tile -->
                                <div class="col-md-4 o_kanban_primary_left">
                                    <button class="btn btn-primary" name="action_view_orders" type="object">
                                        <span class="o_value"><field name="total_revenue" widget="monetary"/></span>
                                        <span class="o_label">Total Revenue</span>
                                    </button>
                                </div>
                                <!-- Orders Tile -->
                                <div class="col-md-4">
                                    <button class="btn btn-primary" name="action_view_orders" type="object">
                                        <span class="o_value"><field name="total_orders"/></span>
                                        <span class="o_label">Total Orders</span>
                                    </button>
                                </div>
                                <!-- Average Order Value Tile -->
                                <div class="col-md-4">
                                    <div class="o_kanban_primary_right">
                                        <span class="o_value"><field name="average_order_value" widget="monetary"/></span>
                                        <span class="o_label">Avg Order Value</span>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <!-- Margin Tile -->
                                <div class="col-md-4">
                                    <div class="o_kanban_primary_left">
                                        <span class="o_value"><field name="total_margin" widget="monetary"/></span>
                                        <span class="o_label">Total Margin</span>
                                    </div>
                                </div>
                                <!-- Profit Percentage Tile -->
                                <div class="col-md-4">
                                    <div>
                                        <span class="o_value"><field name="profit_margin_percentage" widget="percentage"/></span>
                                        <span class="o_label">Profit Margin %</span>
                                    </div>
                                </div>
                                <!-- Payment Status Tile -->
                                <div class="col-md-4">
                                    <button class="btn btn-success" name="action_view_paid_orders" type="object">
                                        <span class="o_value"><field name="paid_orders"/></span>
                                        <span class="o_label">Paid Orders</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- POS Dashboard Action -->
    <record id="action_pos_dashboard" model="ir.actions.act_window">
        <field name="name">POS Dashboard</field>
        <field name="res_model">pos.dashboard</field>
        <field name="view_mode">kanban,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                POS Dashboard
            </p>
            <p>
                Monitor your Point of Sale performance with key metrics and statistics.
            </p>
        </field>
    </record>

</odoo>
