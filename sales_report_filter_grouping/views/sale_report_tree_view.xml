<odoo>
    <!-- Inherit Sale Report Tree View to add Point of Sale column and Vape Status -->
    <record id="view_sale_report_tree_inherit_pos" model="ir.ui.view">
        <field name="name">sale.report.tree.inherit.pos</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.sale_report_view_tree"/>
        <field name="arch" type="xml">
            <!-- Make Order Reference visible -->
            <xpath expr="//field[@name='order_reference']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <!-- Add Point of Sale column after product_id -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="pos_config_id" string="Point of Sale" optional="show"/>
            </xpath>
            <!-- Add Cost Price after price_unit -->
            <xpath expr="//field[@name='price_unit']" position="after">
                <field name="cost_price" string="Cost Price" optional="show"/>
            </xpath>
            <!-- Add Vape Status as the LAST column -->
            <xpath expr="//list" position="inside">
                <field name="vape_status" string="Vape Status" widget="badge"
                       decoration-success="vape_status == 'done'"
                       decoration-info="vape_status == 'send_to_courier'"
                       decoration-warning="vape_status == 'sales_order'"
                       decoration-muted="vape_status == 'quotation'"/>
            </xpath>
        </field>
    </record>

    <!-- Custom list view with cost price and all fields (replaces sale_cost_report) -->
    <record id="sale_report_costprice_list" model="ir.ui.view">
        <field name="name">sale.report.costprice.list</field>
        <field name="model">sale.report</field>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <list string="Sales Report with Cost Price">
                <field name="date"/>
                <field name="order_reference" optional="show"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="pos_config_id" optional="show"/>
                <field name="product_uom_qty"/>
                <field name="price_unit"/>
                <field name="cost_price"/>
                <field name="price_total"/>
                <field name="vape_status" string="Vape Status" widget="badge"
                       decoration-success="vape_status == 'done'"
                       decoration-info="vape_status == 'send_to_courier'"
                       decoration-warning="vape_status == 'sales_order'"
                       decoration-muted="vape_status == 'quotation'"
                       optional="show"/>
            </list>
        </field>
    </record>

    <!-- Inherit Sale Report Pivot View to add Point of Sale -->
    <record id="view_sale_report_pivot_inherit_pos" model="ir.ui.view">
        <field name="name">sale.report.pivot.inherit.pos</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_pivot"/>
        <field name="arch" type="xml">
            <!-- Add Point of Sale as available field in pivot -->
            <xpath expr="//pivot" position="attributes">
                <attribute name="sample">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit Sale Report Graph View to add Point of Sale -->
    <record id="view_sale_report_graph_inherit_pos" model="ir.ui.view">
        <field name="name">sale.report.graph.inherit.pos</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_graph"/>
        <field name="arch" type="xml">
            <!-- Point of Sale will be automatically available in graph grouping -->
            <xpath expr="//graph" position="attributes">
                <attribute name="sample">1</attribute>
            </xpath>
        </field>
    </record>

</odoo>