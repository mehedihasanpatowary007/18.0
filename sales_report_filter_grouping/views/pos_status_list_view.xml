<odoo>
    <!-- POS Status Dashboard List View -->
    <record id="view_pos_order_list_status_dashboard" model="ir.ui.view">
        <field name="name">pos.order.list.status.dashboard</field>
        <field name="model">pos.order</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list string="POS Status Dashboard">
                <field name="name" string="Number"/>
                <field name="date_order" string="Order Date" optional="show"/>
                <field name="partner_id" string="Customer"/>
                <field name="user_id" string="Employee" optional="show"/>
                <field name="company_id" string="Company" optional="show" groups="base.group_multi_company"/>
                <field name="amount_total" string="Total" sum="Total" optional="show"/>
                <field name="priority_level" string="Priority Level" optional="show"/>
                <field name="customer_segment" string="Customer Segment" optional="show"/>
                <field name="payment_status" string="Payment Status" optional="show"/>
                <field name="report_category" string="Report Category" optional="hide"/>
                <field name="sales_region" string="Sales Region" optional="hide"/>
                <field name="session_state" string="Session State" optional="show"/>
                <field name="state" string="Status" widget="badge" optional="show"
                       decoration-success="state == 'paid' or state == 'done' or state == 'invoiced'"
                       decoration-info="state == 'draft'"/>
                <field name="config_id" string="Point of Sale" optional="show"/>
                <field name="session_id" string="Session" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- POS Orders List View with Enhanced Columns -->
    <record id="view_pos_order_list_enhanced" model="ir.ui.view">
        <field name="name">pos.order.list.enhanced</field>
        <field name="model">pos.order</field>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <list string="POS Orders" create="false">
                <field name="name" string="Order Ref"/>
                <field name="session_id" string="Session" optional="hide"/>
                <field name="date_order" string="Date" optional="show"/>
                <field name="config_id" string="Point of Sale" optional="show"/>
                <field name="pos_reference" string="Receipt Number" optional="hide"/>
                <field name="partner_id" string="Customer" optional="show"/>
                <field name="user_id" string="Employee" optional="show"/>
                <field name="amount_total" string="Total" sum="Total" optional="show"/>
                <field name="priority_level" string="Priority Level" optional="show"/>
                <field name="customer_segment" string="Customer Segment" optional="show"/>
                <field name="payment_status" string="Payment Status" optional="show"/>
                <field name="report_category" string="Report Category" optional="hide"/>
                <field name="sales_region" string="Sales Region" optional="hide"/>
                <field name="session_state" string="Session State" optional="hide"/>
                <field name="state" string="Status" optional="show" widget="badge"
                       decoration-success="state in ['paid', 'done', 'invoiced']"
                       decoration-info="state == 'draft'"/>
                <field name="company_id" string="Company" optional="hide" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

</odoo>
