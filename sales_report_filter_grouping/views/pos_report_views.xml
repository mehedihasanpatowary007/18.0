<odoo>
    <!-- POS Report Analysis Pivot View -->
    <record id="view_pos_order_pivot_report_analysis" model="ir.ui.view">
        <field name="name">pos.order.pivot.report.analysis</field>
        <field name="model">pos.order</field>
        <field name="arch" type="xml">
            <pivot string="POS Report Analysis" sample="1">
                <field name="sales_region" type="row"/>
                <field name="report_category" type="row"/>
                <field name="date_order" interval="month" type="col"/>
                <field name="amount_total" type="measure"/>
                <field name="margin" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- POS Report Analysis Graph View -->
    <record id="view_pos_order_graph_report_analysis" model="ir.ui.view">
        <field name="name">pos.order.graph.report.analysis</field>
        <field name="model">pos.order</field>
        <field name="arch" type="xml">
            <graph string="POS Report Analysis" type="bar" sample="1">
                <field name="sales_region"/>
                <field name="amount_total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- POS Report Analysis Action -->
    <record id="action_pos_order_report_analysis" model="ir.actions.act_window">
        <field name="name">POS Report Analysis</field>
        <field name="res_model">pos.order</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="context">{
            'search_default_posted': 1,
            'pivot_measures': ['amount_total', 'margin'],
            'pivot_row_groupby': ['sales_region', 'report_category'],
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No POS data to analyze yet!
            </p>
            <p>
                This view provides advanced POS sales analysis with filtering and grouping capabilities.
            </p>
        </field>
    </record>

    <!-- View bindings for POS Report Analysis Action -->
    <record id="action_pos_report_analysis_view_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_pos_order_pivot_report_analysis"/>
        <field name="act_window_id" ref="action_pos_order_report_analysis"/>
    </record>

    <record id="action_pos_report_analysis_view_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_pos_order_graph_report_analysis"/>
        <field name="act_window_id" ref="action_pos_order_report_analysis"/>
    </record>

    <record id="action_pos_report_analysis_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="action_pos_order_report_analysis"/>
    </record>

    <record id="action_pos_report_analysis_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="4"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="act_window_id" ref="action_pos_order_report_analysis"/>
    </record>

</odoo>
