<odoo>
    <record id="view_account_payment_form_inherit_bank_charge" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.bank.charge</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
<xpath expr="//field[@name='amount']/.." position="after">
    <div>
      <group invisible="processed != True">
           
           <field name="net_amount" readonly="1" />
        </group>
     </div>
</xpath>

<xpath expr="//field[@name='memo']" position="after">
       <div>
          <group string="Bank Charges" invisible="processed != True" >
            <field name="bank_charge_amount" readonly="1"/>
            <field name="bank_charge_total" readonly="1"/>
            <field name="bank_charge_account_id" readonly="1"/>
        </group>
    </div>
</xpath>

        </field>
    </record>
</odoo>
