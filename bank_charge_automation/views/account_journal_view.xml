<odoo>
    <record id="view_account_journal_form_inherit_bank_charge" model="ir.ui.view">
        <field name="name">account.journal.form.bank.charge</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">

            <!-- Add new tab under notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Bank Charges">
                    <group>
                        <field name="has_bank_fees"/>
                        <field name="bank_charge_amount" 
                               modifiers="{'invisible': [('has_bank_fees','=',False)]}"/>
                        <field name="bank_charge_account_id" 
                               modifiers="{'invisible': [('has_bank_fees','=',False)]}"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>

