<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_age_verification" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.age.verification</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//app[@name='website']" position="inside">
                <block title="Age Verification" id="age_verification_settings">

                    <!-- Logo Upload -->
                    <setting string="Popup Logo">
                        <div class="content-group">
                            <div class="row mt8">
                                <label class="col-lg-3 o_light_label" for="age_logo"/>
                                <field name="age_logo" widget="image" class="oe_avatar"
                                       options="{'preview_image': 'age_logo', 'size': [200, 200]}"/>
                            </div>
                            <div class="text-muted">
                                Recommended size: 200x200 pixels. This logo will appear at the top of the age verification popup.
                            </div>
                        </div>
                    </setting>

                    <!-- Basic Settings -->
                    <setting>
                        <div class="content-group">

                            <div class="row mt8">
                                <label class="col-lg-3" string="Popup Title" for="age_title"/>
                                <field name="age_title" placeholder="AGE VERIFICATION"/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="Main Message" for="age_message"/>
                                <field name="age_message" placeholder="The products available are age-restricted..."/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="Sub Message" for="age_message_sub"/>
                                <field name="age_message_sub" widget="text" placeholder="By entering our website..."/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="Fallback URL" for="age_fallback_url"/>
                                <field name="age_fallback_url" placeholder="https://example.com"/>
                            </div>

                            <!-- ❌ Popup Style field removed because it no longer exists -->
                        </div>
                    </setting>

                    <!-- Style Customization (Simple Professional System) -->
                    <setting string="Style Customization">
                        <div class="content-group">

                            <div class="row mt8">
                                <label class="col-lg-3" string="Popup Title Background" for="age_title_bg"/>
                                <field name="age_title_bg" widget="color"/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="Main Background" for="age_main_bg"/>
                                <field name="age_main_bg" widget="color"/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="Yes Button Background" for="age_yes_bg"/>
                                <field name="age_yes_bg" widget="color"/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="No Button Background" for="age_no_bg"/>
                                <field name="age_no_bg" widget="color"/>
                            </div>

                            <div class="row mt8">
                                <label class="col-lg-3" string="Text Color" for="age_text_color"/>
                                <field name="age_text_color" widget="color"/>
                            </div>

                        </div>
                    </setting>

                </block>
            </xpath>

        </field>
    </record>
</odoo>
