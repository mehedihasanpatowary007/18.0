<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t  t-inherit="sale.ProductConfiguratorDialog" t-inherit-mode="extension">
        <xpath expr="//Dialog//ProductList[1]" position="replace">
            <t t-log="this.props.quantity"/>
                <ProductList t-if="this.state.products.length" products="this.state.products" 
                    display_product_qty_limits = "this.state.display_product_qty_limits"
                    minimum_product_quantity = "this.state.minimum_product_quantity"
                    maximum_product_quantity = "this.state.maximum_product_quantity"
                    product_quantity_multipler = "this.state.product_quantity_multipler"
                />
        </xpath>
    </t>
</templates>
