<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t  t-inherit="sale.ComboConfiguratorDialog" t-inherit-mode="extension">
        <xpath expr="//Dialog//t[@t-set-slot='footer']//div[2]//QuantityButtons" position="replace">
            <t t-if="state.display_product_qty_limits">
                <QuantityButtons
                    quantity="state.quantity"
                    setQuantity="quantity => this.setQuantity(quantity)"
                    btnClasses="'d-inline-block w-auto'"
                    isMinusButtonDisabled="state.quantity === state.minimum_product_quantity"
                    isPlusButtonDisabled="state.quantity === state.maximum_product_quantity"
                    display_product_qty_limits = "state.display_product_qty_limits"
                    minimum_product_quantity = "state.minimum_product_quantity"
                    maximum_product_quantity = "state.maximum_product_quantity"
                    product_quantity_multipler = "state.product_quantity_multipler"
                    /> 
            </t>
            <t t-else="">
                <QuantityButtons
                        quantity="state.quantity"
                        setQuantity="quantity => this.setQuantity(quantity)"
                        btnClasses="'d-inline-block w-auto'"
                        isMinusButtonDisabled="state.quantity === 1"
                        display_product_qty_limits = "state.display_product_qty_limits"
                        minimum_product_quantity = "state.minimum_product_quantity"
                        maximum_product_quantity = "state.maximum_product_quantity"
                        product_quantity_multipler = "state.product_quantity_multipler"
                    />
            </t>
        </xpath>
    </t>
</templates>
