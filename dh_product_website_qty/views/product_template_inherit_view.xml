<odoo>
	<record id="dh_product_website_qty_product_template_form_view" model="ir.ui.view">
		<field name="name">sh.product.website.qty.product.template.form.view</field>
		<field name="model">product.template</field>
		<field name="inherit_id" ref="website_sale.product_template_form_view"/>
		<field name="arch" type="xml">
			<xpath expr="//group[@name='extra_info']" position="inside">
				<field name="display_product_qty_limits"/>
				<field name="minimum_product_quantity" invisible="not display_product_qty_limits"/>
				<field name="maximum_product_quantity" invisible="not display_product_qty_limits"/>
				<field name="product_quantity_multipler" invisible="not display_product_qty_limits"/>
			</xpath>
		</field>
	</record>
</odoo>