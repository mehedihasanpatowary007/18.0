<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit purchase order form view for adding Twilio SMS button -->
    <record id="purchase_order_form_betopia_sms" model="ir.ui.view">
    <field name="name">purchase.order.view.form.inherit.betopia.sms</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
        <header position="inside">
            <button name="action_purchase_sms"
                    type="object"
                    string="Send SMS"
                    class="oe_highlight"/>
        </header>
    </field>
</record>
    <record id="sale_order_form_betopia_sms" model="ir.ui.view">
        <field name="name">sale.order.view.form.inherit.betopia.sms</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_sale_sms"
                        type="object"
                        string="Send SMS"
                        class="oe_highlight"/>
            </header>
        </field>
    </record>

    <record id="account_move_form_betopia_sms" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit.betopia.sms</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_invoice_sms"
                        type="object"
                        string="Send SMS"
                        class="oe_highlight"/>
            </header>
        </field>
    </record>
    <record id="account_payment_form_betopia_sms" model="ir.ui.view">
        <field name="name">account.payment.view.form.inherit.betopia.sms</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_payment_sms"
                        type="object"
                        string="Send SMS"
                        class="oe_highlight"/>
            </header>
        </field>
    </record>

</odoo>
