<odoo>
  <data>

    <!-- FORM VIEW -->
    <record id="view_form_sms_message" model="ir.ui.view">
      <field name="name">betopia.sms.message.view.form</field>
      <field name="model">betopia.sms.message</field>
      <field name="type">form</field>
      <field name="arch" type="xml">
        <form string="SMS Message">
          <sheet>
            <group>
              <field name="partner_id" readonly="1" />
              <field name="mobile_number" placeholder="Enter recipient number" required="1"
                readonly="1" />
              <field name="sms_account" readonly="1" />
            </group>
            <group>
              <field name="body" widget="text" placeholder="Type your message here..." required="1"
                readonly="1" />
              <field name="response" readonly="1" />
            </group>

          </sheet>
        </form>
      </field>
    </record>

    <!-- TREE (LIST) VIEW -->
    <record id="view_tree_sms_message" model="ir.ui.view">
      <field name="name">betopia.sms.message.view.list</field>
      <field name="model">betopia.sms.message</field>
      <field name="arch" type="xml">
        <list string="SMS Messages">

          <field name="mobile_number" />

          <field name="body" />
          <field name="state" />
        </list>
      </field>
    </record>

    <!-- ACTION -->
    <record id="action_sms_message" model="ir.actions.act_window">
      <field name="name">SMS Messages</field>
      <field name="res_model">betopia.sms.message</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Click to send a new SMS message.
        </p>
      </field>
    </record>


  </data>
</odoo>
