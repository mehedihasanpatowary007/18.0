<odoo>
  <data>
    <!-- Form View -->
    <record id="view_form_betopia_sms_gateway" model="ir.ui.view">
      <field name="name">betopia.sms.gateway.form.view</field>
      <field name="model">betopia.sms.gateway</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="gateway"/>
            </group>

          </sheet>
        </form>
      </field>
    </record>

    <!-- Tree/List View -->
    <record id="view_tree_betopia_sms_gateway" model="ir.ui.view">
      <field name="name">betopia.sms.gateway.tree.view</field>
      <field name="model">betopia.sms.gateway</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="gateway"/>
        </list>
      </field>
    </record>

   <!-- Action -->
<record id="action_betopia_sms_gateway" model="ir.actions.act_window">
  <field name="name">SMS Gateway</field>
  <field name="res_model">betopia.sms.gateway</field>
  <field name="view_mode">list,form</field>
  <field name="type">ir.actions.act_window</field>
</record>

<!-- Menu -->




  </data>
</odoo>
