<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_form_no_negative" model="ir.ui.view">
        <field name="name">pos.config.form.no.negative.stock</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='other_devices']" position="before">
                <setting string="Block Out-of-Stock Products"
                         help="Prevent validating POS orders when storable products exceed available quantity in the POS warehouse stock location.">
                    <field name="block_out_of_stock"/>
                    <div class="content-group mt16" invisible="not block_out_of_stock">
                        <div class="row">
                            <label string="Ignore Consumables" for="block_ignore_consumables"
                                   class="col-lg-4 o_light_label"/>
                            <field name="block_ignore_consumables"/>
                        </div>
                        <div class="row">
                            <label string="Use Forecasted Qty (virtual)" for="block_use_forecast"
                                   class="col-lg-4 o_light_label"/>
                            <field name="block_use_forecast"/>
                        </div>
                        <div class="o_light_label mt8">
                            Uses the POS picking type's warehouse stock location; falls back to the POS stock location.
                        </div>
                    </div>
                </setting>
                <setting string="Low-stock Alert"
                         help="Warn the cashier when an item is close to going out of stock at the POS location.">
                    <field name="low_stock_alert_enabled"/>
                    <div class="content-group mt16" invisible="not low_stock_alert_enabled">
                        <div class="row">
                            <label string="Threshold" for="low_stock_threshold" class="col-lg-4 o_light_label"/>
                            <field name="low_stock_threshold" class="oe_inline"/>
                        </div>
                        <div class="row">
                            <label string="Email recipients" for="low_stock_email_recipients"
                                   class="col-lg-4 o_light_label"/>
                            <field name="low_stock_email_recipients"
                                   placeholder="ops@example.com, manager@example.com"/>
                            <div class="o_light_label">
                                Toast appears when (available − qty in current order) ≤ threshold.
                            </div>
                            <div class="o_light_label">
                                Leave blank if no email notification is to be sent for low-stock.
                            </div>
                        </div>

                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
