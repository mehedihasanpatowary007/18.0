<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.pos.stock.no.negative</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
             <xpath expr="//block[@id='pos_inventory_section']" position="inside">
               <setting string="Restrict Negative Quantity" help="Restrict selling product over available quantity.">
                    <field name="is_restrict_negative"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
