<odoo>
    <record id="view_payment_provider_form_aamarpay" model="ir.ui.view">
        <field name="name">AamarPay Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='provider_credentials']" position="inside">
                <group invisible="code != 'aamar_pay'">
                    <field name="aamarpay_store_id"
                           string="AamarPay Store ID"
                           required="code == 'aamar_pay' and state != 'disabled'"/>
                    <field name="aamarpay_signature_key"
                           string="AamarPay Signature Key"
                           required="code == 'aamar_pay' and state != 'disabled'"
                           password="True"/>
                    <field name="aamarpay_is_sandbox" string="Sandbox Mode"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
